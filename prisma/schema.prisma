/// Beta bulk-photo ingestion. One row per product group submitted from
/// /shop/admin/bulk-add. The bulk-ingest-worker drains these: Gemini vision
/// → Amazon SerpAPI lookup → create Product → enqueue ListingJob for FB.
/// Then walks away — the existing fb-draft-worker handles the rest.
model BulkIngestJob {
  id               String    @id @default(cuid())
  batchId          String
  status           String    @default("queued")
  photoUrls        String[]
  productId        String?
  visionResult     Json?
  amazonAsin       String?
  amazonPriceCents Int?
  confidence       Float?
  attempts         Int       @default(0)
  lastStage        String?
  lastError        String?
  nextAttemptAt    DateTime  @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([batchId])
}

/// WhatsApp chat → shop auto-listing. One row per "scan this chat" request from
/// /shop/whatsapp. The bulk-ingest-worker drains these: pull the chat's photo
/// backlog from the local WhatsApp bridge, smart-group multi-angle shots by
/// caption/time, upload to Vercel Blob, then fan out into BulkIngestJob rows
/// (sharing `batchId`) — which the same worker already turns into Products +
/// FB drafts. Progress for the vision→product half is read off BulkIngestJob.
model WhatsappScanJob {
  id            String    @id @default(cuid())
  chatId        String
  chatName      String?
  count         Int       @default(50)
  groupMode     String    @default("smart") // smart = group multi-angle; single = one listing per photo
  status        String    @default("queued") // queued|scraping|enqueued|failed
  batchId       String? // links to the BulkIngestJob rows this scan produced
  photosFound   Int       @default(0)
  groups        Int       @default(0)
  skipped       Int       @default(0)
  attempts      Int       @default(0)
  lastStage     String?
  lastError     String?
  nextAttemptAt DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([batchId])
}

/// Auto-watch a WhatsApp chat: the bulk-ingest-worker polls each enabled row,
/// pulls photos NEWER than `lastSeenTs` from the bridge, and auto-lists them
/// (group → Blob → BulkIngestJob → Product + FB draft). `lastSeenTs` is the
/// unix-seconds watermark advanced after each run so photos are never re-listed.
model WhatsappWatch {
  id          String    @id @default(cuid())
  chatId      String    @unique
  chatName    String?
  groupMode   String    @default("single")
  count       Int       @default(50)
  lastSeenTs  Int       @default(0)
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  lastError   String?
  lastListed  Int       @default(0)
  totalListed Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([enabled])
}

/// Browser-session auth for marketplaces without a public listing API
/// (Mercari, Poshmark, Depop, FB). One row per platform; the persistent
/// Chromium profile on disk is the actual credential store. We track here
/// so the admin UI can show health without touching the worker.
model PlatformAuth {
  id           String    @id @default(cuid())
  platform     String    @unique
  sessionState String    @default("disabled")
