model YouTubeProject {
  id String @id @default(cuid())

  // Tenant scoping (2026-06-11, pay-per-video launch). Nullable: legacy
  // projects predate multi-tenancy and are admin-only via project-access.ts.
  userId String?

  // Mode + source
  mode          String        @default("transcribe") // "transcribe" | "topic"
  sourceUrl     String?
  sourceTitle   String?
  sourceChannel String?
  sourceType    String        @default("manual") // "manual" | "rss" | "topic"
  rssItemId     String?       @unique
  rssItem       VaterRssItem? @relation(fields: [rssItemId], references: [id])
  topic         String? // used in topic mode only

  // Transcript (transcribe mode only)
  transcript       String?
  transcriptMeta   Json?
  goalSuggestions  Json?
  // TubeGen-parity title suggestions (vater v2 Phase 0). Populated by
  // /api/vater/youtube/[id]/title/generate via autopilot.suggestTitles.
  // Shape: string[]. Cleared when the user commits a sourceTitle.
  titleSuggestions Json?

  // User intent (collected after transcribe, or upfront in topic mode)
  goal            String?
  targetDuration  Int     @default(10) // minutes
  targetWordCount Int     @default(1500)

  // Style + voice
  stylePreset       String  @default("cinematic") // one of 8
  customStylePrompt String?
  voiceCloneId      String?
  voiceName         String?

  // Music + SFX (frontend pickers; SFX injection is v2)
  backgroundMusicId String?
  musicVolume       Float?  @default(0.18)
  sfxEnabled        Boolean @default(false)

  // Creation stage
  sourcePrinciples   Json?
  script             String?
  scriptMeta         Json?
  verifiedScript     Boolean @default(false)
  verificationReport Json?

  // Media
  audioUrl       String?
  audioDuration  Float?
  captionTimings Json? // [{word, start, end}]
  scenesJson     Json? // [{idx, beatText, startS, endS, imagePrompt, imageUrl}]
  finalVideoUrl  String?

  // Status
  status         String    @default("draft")
  progress       Int       @default(0)
  stepDetails    Json?
  errorMessage   String?
  autopilotJobId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  // Post-generation editor (v2) — review + redo scenes before publishing.
  // draftSnapshots is an append-only JSON array: [{ts, scenesJson, audioUrl,
  // backgroundMusicId, thumbnailUrl, note}]. Used for one-click revert.
  draftSnapshots Json?
  thumbnailUrl   String?
  publishedTo    String[]  @default([])
  editedAt       DateTime?

  // ── Batch-animate reconcile anchor (2026-07-02) ─────────────────────
  // The animate-all kickoff returns an animateAllJobId to the client, which
  // bills per-scene ONLY when the client calls /animate-all/finalize. If the
  // tab closes after kickoff the Modal batch still runs but never bills.
  // Persisting the batch job id here lets the invoice-sweep reconciler find
  // done-but-unfinalized batches and backfill `animall_<jobId>_<idx>` usage
  // with the exact per-scene idempotency keys the client path uses.
  animateAllJobId     String?
  animateAllStartedAt DateTime?

  // ── TubeGen-parity Style document (2026-04-14) ──────────────────────
  // styleId is the new path. When NULL, the legacy stylePreset string above
  // remains the source of truth (back-compat with all existing rows).
  styleId String?
  style   YouTubeStyle? @relation(fields: [styleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([sourceType])
  @@index([styleId])
  @@index([userId])
  @@index([animateAllStartedAt])
}

// ── Vater Watcher — embedded Claude observer (2026-04-17) ────────────
// A persistent Claude Code agent on DGX watches every in-flight YouTube
// job via the vater-observer MCP server. It writes human-readable notes
// and actionable proposals through bearer-authed HTTPS so the UI sidebar
// at /vater/youtube can render the feed and route Apply/Dismiss clicks
// to the autopilot client.

model VaterObserverNote {
  id        String   @id @default(cuid())
  jobId     String   @db.VarChar(64)
  projectId String?
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([projectId, createdAt])
}

model VaterObserverProposal {
  id            String    @id @default(cuid())
  jobId         String    @db.VarChar(64)
  projectId     String?
  actionType    String // regen_scene | restart_stage | edit_script | tweak_voice_params | tweak_image_prompt | cancel_job
  params        Json
  reasoning     String    @db.Text
  status        String    @default("pending") // pending | applied | dismissed | failed
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resultSummary String?   @db.Text

  @@index([jobId, status, createdAt])
  @@index([projectId, status, createdAt])
}

// ── Vater Studio billing (2026-04-26) ─────────────────────────────────
// Pure dollar-denominated, NO credits. Mirrors Claude.ai usage UX.
//
// Architecture:
//  - $288/month VaterSubscription (Stripe Subscription, separate from Food/Leads)
//  - $250 included usage refills every period via Stripe Credit Grant
//  - Each chargeable action posts a Stripe InvoiceItem (line item) to the
//    upcoming invoice; we mirror it in VaterUsage for live UI + analytics
//  - VaterTrialUsage tracks free-tier caps (3 transcripts / 1 scene / 1 anim)
//  - VaterMonthlyLimit enforces user-set spending cap before paid actions
//
// Pattern follows FoodHousehold (each product owns its own Stripe state,
// avoiding the legacy User.subscriptionStatus single-tenant problem).

model VaterSubscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe identifiers
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  stripeCreditGrantId  String? // legacy ($288/mo credit-grant model) — unused since 2026-06

  // Card on file (pay-per-video model, set by setup-mode Checkout webhook)
  defaultPaymentMethodId String?
  cardBrand              String?
  cardLast4              String?
  cardExpMonth           Int?
  cardExpYear            Int?
  delinquentAt           DateTime? // set when an invoice fails; cleared on invoice.paid

  // Lifecycle state: trialing = no card on file · active = card on file ·
  // past_due = invoice failed (delinquent)
  status             String    @default("trialing") // trialing | active | past_due | canceled | none
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  // Trial tracking (usage-only — no calendar timer)
  trialEndedAt     DateTime? // set when paywall fires AND user converts
  trialConvertedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// Immutable ledger of every chargeable action. Mirrors Stripe InvoiceItems
/// so we can render live usage + analytics without round-tripping to Stripe
/// on every page render.
model VaterUsage {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action              String // 'script' | 'voiceover' | 'scene' | 'animation' | 'render' | 'thumbnail' | 'description' | 'transcription'
  tier                String? // 'dgx' | 'l40s' | 'b100' | null (for tier-agnostic actions)
  costCents           Int // mirror of the Stripe InvoiceItem amount in cents
  description         String? // human-readable summary ("Scene 3 — L40S")
  projectId           String? // YouTubeProject.id when applicable
  ts                  DateTime @default(now())
  // Stripe sync
  stripeInvoiceItemId String?  @unique
  // Stamped when the invoice containing this item finalizes+pays — unbilled
  // accrual = rows with stripeInvoiceItemId set but stripeInvoiceId null
  stripeInvoiceId     String?
  // Idempotency: when a route retries, we want the same key to dedupe
  idempotencyKey      String?  @unique

  @@index([userId, ts])
  @@index([userId, action, ts])
  @@index([userId, stripeInvoiceId])
  @@index([projectId])
}

/// Per-user free-tier cap counters. One row per user, created on first action.
model VaterTrialUsage {
  userId      String    @id
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcripts Int       @default(0)
  scenes      Int       @default(0)
  animations  Int       @default(0)
  firstUsedAt DateTime  @default(now())
  capHitAt    DateTime? // first time any cap was reached
}

/// User-set monthly spending limit. Enforced app-side before chargeable
/// actions: if (monthSpendCents + actionCostCents > limitCents) → block.
model VaterMonthlyLimit {
  userId      String    @id
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  limitCents  Int       @default(50000) // $500/mo default
  // periodStart anchors which month we're tracking; reset by webhook on invoice.paid
  periodStart DateTime  @default(now())
  // usedCents is a CACHE — truth is sum(VaterUsage.costCents WHERE ts >= periodStart)
  usedCents   Int       @default(0)
  // when the user has explicitly raised the limit mid-period via the modal
  raisedAt    DateTime?
  updatedAt   DateTime  @updatedAt
}

// ── TubeGen-parity Style/Character/CustomArtStyle (2026-04-14) ────────
// The Style is a reusable container — voice, script defaults, reference
// transcripts (script few-shot corpus), characters, custom art style, and
// smart-overlay toggles. Modeled after TubeGen's MongoDB Style document
// observed in research at /tmp/tubegen-research/api-dumps/finance-style.json.
//
// userId == NULL means a system-owned seed row (read-only, cloneable).
// Editing a system row returns 403; clones become user-owned and editable.

model YouTubeStyle {
  id     String  @id @default(cuid())
  userId String?
  name   String
  emoji  String  @default("🎨")

  // Voice
  voice             String  @default("MorganDeep")
  voiceCloneId      String?
  voiceSpeed        Float   @default(1.0)
  voiceStability    Float   @default(1.0)
  voiceSimilarity   Float   @default(1.0)
  voiceExaggeration Float   @default(0.0)
  voiceBackend      String  @default("f5-tts") // f5-tts | elevenlabs
  language          String  @default("en")

  // Script
  defaultWordCount     Int     @default(1500)
  scriptMode           String  @default("default") // default | few_shot | story
  webSearchDefault     Boolean @default(false)
  additionalContext    String?
  // [{videoId, url, title, wordCount, transcript, addedAt}] — script few-shot corpus
  referenceTranscripts Json?

  // Visual defaults
  artStylePresetId   String  @default("cinematic") // matches STYLE_PRESETS id
  customArtStyleId   String?
  defaultAspectRatio String  @default("16x9")
  // firered-local (default, local DGX + Qwen-Image-Edit arch) | gemini-1k | gemini-2k
  // | sdxl-local | sdxl-ipadapter | flux-schnell | ideogram-default | ideogram-turbo | ideogram-quality
  defaultQuality     String  @default("firered-local")
  // images | animated | broll | broll-mix
  defaultVisualType  String  @default("images")
  defaultAnimMode    String  @default("none") // none | all | longer-only
  defaultAnimMin     Int     @default(2)
  defaultAnimMax     Int     @default(8)
  defaultPacingSec   Float? // null = preset/global default
  defaultConsistency Int     @default(0)

  // Smart-overlay defaults
  enableCharts      Boolean @default(false)
  enableMaps        Boolean @default(false)
  enableAutoHeaders Boolean @default(false)
  overlayTheme      String  @default("dark")

  // Provenance
  isSystem     Boolean        @default(false)
  clonedFromId String?
  clonedFrom   YouTubeStyle?  @relation("StyleClones", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones       YouTubeStyle[] @relation("StyleClones")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters     YouTubeCharacter[]
  customArtStyle CustomArtStyle?    @relation(fields: [customArtStyleId], references: [id], onDelete: SetNull)
  projects       YouTubeProject[]

  @@index([userId])
  @@index([isSystem])
}

model YouTubeCharacter {
  id                String       @id @default(cuid())
  styleId           String
  style             YouTubeStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)
  name              String
