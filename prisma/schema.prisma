model YouTubeProject {
  id String @id @default(cuid())

  // Mode + source
  mode          String        @default("transcribe") // "transcribe" | "topic"
  sourceUrl     String?
  sourceTitle   String?
  sourceChannel String?
  sourceType    String        @default("manual") // "manual" | "rss" | "topic"
  rssItemId     String?       @unique
  rssItem       VaterRssItem? @relation(fields: [rssItemId], references: [id])
  topic         String? // used in topic mode only

  // Transcript (transcribe mode only)
  transcript      String?
  transcriptMeta  Json?
  goalSuggestions Json?

  // User intent (collected after transcribe, or upfront in topic mode)
  goal            String?
  targetDuration  Int     @default(10) // minutes
  targetWordCount Int     @default(1500)

  // Style + voice
  stylePreset       String  @default("cinematic") // one of 8
  customStylePrompt String?
  voiceCloneId      String?
  voiceName         String?

  // Music + SFX (frontend pickers; SFX injection is v2)
  backgroundMusicId String?
  musicVolume       Float?  @default(0.18)
  sfxEnabled        Boolean @default(false)

  // Creation stage
  sourcePrinciples   Json?
  script             String?
  scriptMeta         Json?
  verifiedScript     Boolean @default(false)
  verificationReport Json?

  // Media
  audioUrl       String?
  audioDuration  Float?
  captionTimings Json? // [{word, start, end}]
  scenesJson     Json? // [{idx, beatText, startS, endS, imagePrompt, imageUrl}]
  finalVideoUrl  String?

  // Status
  status         String    @default("draft")
  progress       Int       @default(0)
  stepDetails    Json?
  errorMessage   String?
  autopilotJobId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  // Post-generation editor (v2) — review + redo scenes before publishing.
  // draftSnapshots is an append-only JSON array: [{ts, scenesJson, audioUrl,
  // backgroundMusicId, thumbnailUrl, note}]. Used for one-click revert.
  draftSnapshots Json?
  thumbnailUrl   String?
  publishedTo    String[]  @default([])
  editedAt       DateTime?

  // ── TubeGen-parity Style document (2026-04-14) ──────────────────────
  // styleId is the new path. When NULL, the legacy stylePreset string above
  // remains the source of truth (back-compat with all existing rows).
  styleId String?
  style   YouTubeStyle? @relation(fields: [styleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([sourceType])
  @@index([styleId])
}

// ── TubeGen-parity Style/Character/CustomArtStyle (2026-04-14) ────────
// The Style is a reusable container — voice, script defaults, reference
// transcripts (script few-shot corpus), characters, custom art style, and
// smart-overlay toggles. Modeled after TubeGen's MongoDB Style document
// observed in research at /tmp/tubegen-research/api-dumps/finance-style.json.
//
// userId == NULL means a system-owned seed row (read-only, cloneable).
// Editing a system row returns 403; clones become user-owned and editable.

model YouTubeStyle {
  id     String  @id @default(cuid())
  userId String?
  name   String
  emoji  String  @default("🎨")

  // Voice
  voice             String  @default("MorganDeep")
  voiceCloneId      String?
  voiceSpeed        Float   @default(1.0)
  voiceStability    Float   @default(1.0)
  voiceSimilarity   Float   @default(1.0)
  voiceExaggeration Float   @default(0.0)
  voiceBackend      String  @default("f5-tts") // f5-tts | elevenlabs
  language          String  @default("en")

  // Script
  defaultWordCount     Int     @default(1500)
  scriptMode           String  @default("default") // default | few_shot | story
  webSearchDefault     Boolean @default(false)
  additionalContext    String?
  // [{videoId, url, title, wordCount, transcript, addedAt}] — script few-shot corpus
  referenceTranscripts Json?

  // Visual defaults
  artStylePresetId   String  @default("cinematic") // matches STYLE_PRESETS id
  customArtStyleId   String?
  defaultAspectRatio String  @default("16x9")
  // sdxl-local | sdxl-ipadapter | flux-schnell | gemini-1k | gemini-2k | ideogram-default
  defaultQuality     String  @default("sdxl-local")
  // images | animated | broll | broll-mix
  defaultVisualType  String  @default("images")
  defaultAnimMode    String  @default("none") // none | all | longer-only
  defaultAnimMin     Int     @default(2)
  defaultAnimMax     Int     @default(8)
  defaultPacingSec   Float? // null = preset/global default
  defaultConsistency Int     @default(0)

  // Smart-overlay defaults
  enableCharts      Boolean @default(false)
  enableMaps        Boolean @default(false)
  enableAutoHeaders Boolean @default(false)
  overlayTheme      String  @default("dark")

  // Provenance
  isSystem     Boolean        @default(false)
  clonedFromId String?
  clonedFrom   YouTubeStyle?  @relation("StyleClones", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones       YouTubeStyle[] @relation("StyleClones")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters     YouTubeCharacter[]
  customArtStyle CustomArtStyle?    @relation(fields: [customArtStyleId], references: [id], onDelete: SetNull)
  projects       YouTubeProject[]

  @@index([userId])
  @@index([isSystem])
}

model YouTubeCharacter {
  id                String       @id @default(cuid())
  styleId           String
  style             YouTubeStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)
  name              String
  description       String       @db.Text
  briefDescription  String?
  imageUrl          String?
  imageKey          String?
  permanent         Boolean      @default(true)
  placeInEveryImage Boolean      @default(false)
  customArtStyleId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([styleId])
}

model CustomArtStyle {
  id                 String   @id @default(cuid())
  userId             String?
  name               String
  description        String   @db.Text
  referenceImageUrls String[]
  thumbnailUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  styles YouTubeStyle[]

  @@index([userId])
}
