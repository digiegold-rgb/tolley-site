// ─── Follow-Up Drip Sequences ────────────────────────────

model SmsSequence {
  id              String            @id @default(cuid())
  subscriberId    String
  name            String
  description     String?
  isActive        Boolean           @default(true)
  targetSource    String[]          // lead sources this applies to
