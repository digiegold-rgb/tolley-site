// A saved delivery-run template for a customer. Lets recurring runs (e.g. Wayne
// Clark / Aramsco's granite drops) be re-billed in one click: pick the run and
// a DRAFT invoice is generated pre-filled with the drop + miles * rate.
model RegularRun {
  id           String         @id @default(cuid())
  contactId    String
  label        String // short button label, e.g. "Gaumats — Grain Valley"
  dropLocation String // becomes the invoice line description
  // billingMode "MILEAGE": line = miles * rate ($/mi), e.g. Wayne/Aramsco.
  // billingMode "FLAT":    line = a single flat charge (rate = default $), for
  //                        weight-based clients (e.g. Guadalupe) where the $
  //                        changes weekly — the default is edited before send.
  billingMode  String         @default("MILEAGE")
  miles        Float // default miles (MILEAGE mode); ignored/1 for FLAT
  rate         Float          @default(3) // $ per mile (MILEAGE) or flat $ default (FLAT)
  notes        String?
  sortOrder    Int            @default(0)
  active       Boolean        @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  contact      AccountContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, active, sortOrder])
}

