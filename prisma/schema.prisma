  plaidId              String?         @unique
  reconciliationStatus String?
  stripePayoutId       String?
  taxCategory          String?
  bankAccount          LedgerAccount?  @relation(fields: [bankAccountId], references: [id])
  contact              AccountContact? @relation(fields: [contactId], references: [id])

  @@index([accountCode, date])
  @@index([bankAccountId, date])
  @@index([date(sort: Desc)])
  @@index([incomeSource])
  @@index([needsReview, date])
  @@index([source, date])
  @@index([taxCategory])
  @@index([type, date])
}

