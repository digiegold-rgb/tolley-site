  retailerLabel   String
  externalId      String // retailer SKU / product id
  title           String
  imageUrl        String?
  productUrl      String?
  brand           String?
  model           String?
  zip             String?
  buyPrice        Float
  originalPrice   Float?
  savings         Float? // dollars off (original - buyPrice)
  discountPct     Float? // % off original (primary deal signal)
  promoType       String? // e.g. Special-Buy, Clearance
  onClearance     Boolean   @default(false)
  storeName       String?
  inStockQty      Int?
  resaleMedian    Float? // eBay resale comp (gross) — optional validation
  resaleNetMedian Float? // after fees+shipping haircut
  resaleSamples   Int       @default(0)
  estProfit       Float? // resaleNetMedian - buyPrice (when comped)
  marginPct       Float? // resale margin % (when comped)
