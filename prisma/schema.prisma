  nationalHealth      Float?   // 0-100
  localKcHealth       Float?   // 0-100
  mortgage30yr        Float?
  mortgage15yr        Float?
  treasury10yr        Float?
  treasury30yr        Float?
  unemployment        Float?
  cpi                 Float?
  consumerSentiment   Float?
  housingStarts       Float?
  tickers             Json?    // { VNQ: { price, change }, ITB: {...}, ... }
  topSignals          Json?    // array of signal summaries
  dataPointCount      Int      @default(0)
  signalCount         Int      @default(0)
  summary             String?  // AI-generated daily market summary
  momentum            Float?   // -100 to +100 composite momentum
  healthDelta         Float?   // nationalHealth change from yesterday
  kcHealthDelta       Float?   // localKcHealth change from yesterday
  sentimentBullPct    Float?   // % bullish articles today
  sentimentBearPct    Float?   // % bearish articles today
