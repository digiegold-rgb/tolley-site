// Imported revenue from Numbers/Excel sheets — multi-business, line-item.
// One row per item-line on a source sheet. Aggregations done on read.
model RevenueEntry {
  id           String    @id @default(cuid())
  business     String // "Flips", "Table Rentals", "Extra Extra!", "Cards for Flip", etc.
  channel      String? // sub-channel (e.g. "Cargo Largo", "Crazy Bin Store - Jan")
  itemDesc     String?
  date         DateTime?
  gross        Float?
  cost         Float?
  fees         Float?
  profit       Float?
  inventoryRem Float?
  notes        String?

  sourceFile    String
  sourceSheet   String
  sourceRowIdx  Int
  importBatchId String
  importBatch   RevenueImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importedAt    DateTime           @default(now())

  // Stable dedup key so re-imports update existing rows in place.
  dedupKey String @unique

  @@index([business, date])
  @@index([business, channel])
  @@index([importBatchId])
}

model RevenueImportBatch {
  id           String                  @id @default(cuid())
  sourceFile   String
  sheetCount   Int
  rowsImported Int
  rowsSkipped  Int
  rowsUpdated  Int                     @default(0)
  notes        String?
  createdAt    DateTime                @default(now())
  entries      RevenueEntry[]
  totals       RevenueBusinessTotals[]

  @@index([createdAt])
}

// Authoritative per-business totals as reported by the source workbook's
// own Totals tabs. Surfaced as the headline numbers on the dashboard so
// what we display matches what the user sees in Numbers.
model RevenueBusinessTotals {
  id               String             @id @default(cuid())
  business         String
  sourceFile       String
  sourceSheet      String
  gross            Float?
  cost             Float?
  profit           Float?
  profitOptimistic Float?
  inventoryRem     Float?
  importBatchId    String
  importBatch      RevenueImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importedAt       DateTime           @default(now())

  @@unique([sourceFile, business, sourceSheet])
  @@index([business])
}

model TradingAgentDecision {
  id                 String   @id @default(cuid())
  ticker             String
  runDate            String
  decision           String
  rawDecision        String?
  elapsedSeconds     Float?
  fundamentalsReport String?  @db.Text
  sentimentReport    String?  @db.Text
  newsReport         String?  @db.Text
  marketReport       String?  @db.Text
  bullHistory        String?  @db.Text
  bearHistory        String?  @db.Text
  investmentPlan     String?  @db.Text
  traderPlan         String?  @db.Text
  riskJudgeDecision  String?  @db.Text
  finalTradeDecision String?  @db.Text
  realizedReturn     Float?
  alphaVsSpy         Float?
  jobId              String?
  modelUsed          String?
  createdAt          DateTime @default(now())

  @@unique([ticker, runDate])
  @@index([ticker, createdAt])
  @@index([createdAt])
}

model SerpapiQuery {
  id          String   @id @default(cuid())
  integration String
  engine      String
  query       String   @db.Text
  success     Boolean
  costUnits   Int      @default(1)
  status      Int?
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([integration, createdAt])
  @@index([createdAt])
}

// Maps Pack rank tracking — weekly cron snapshots GBP positions for tolley.io
// businesses across a configured set of (keyword, lat/lng) pairs. Each row is
// one keyword/zip/business observation per run.
model MapsPackRank {
  id           String   @id @default(cuid())
  keyword      String
  zip          String
  lat          Float
  lng          Float
  businessName String
  position     Int? // null = not in top 20
  totalResults Int?
  placeId      String?
  rating       Float?
  reviews      Int?
  rawTitle     String?
  rawAddress   String?
  createdAt    DateTime @default(now())

  @@index([keyword, zip, businessName, createdAt])
  @@index([createdAt])
}

// AI Overview citation tracking — periodic check whether tolley.io URLs are
// cited in Google's AI Overview block for target keywords.
model AiOverviewCheck {
  id              String   @id @default(cuid())
  keyword         String
  hasOverview     Boolean
  tolleyCited     Boolean
  citedDomains    String[] @default([])
  competitorCount Int      @default(0)
  overviewText    String?  @db.Text
  rawJson         Json?
  createdAt       DateTime @default(now())

  @@index([keyword, createdAt])
  @@index([createdAt])
}

// Maps Pack snapshot — full top-N GBPs returned for a (keyword, zip) pair on
// a single run. Lets us see exactly who outranks us and by how much (review
// counts, ratings) without re-querying.
model MapsPackSnapshot {
  id           String   @id @default(cuid())
  keyword      String
  zip          String
  lat          Float
  lng          Float
  // Array of { position, title, place_id, rating, reviews, address }
  topResults   Json
  totalResults Int
  createdAt    DateTime @default(now())

  @@index([keyword, zip, createdAt])
  @@index([createdAt])
}

// Review-request automation — operator queues SMS/email asks to past clients
// pointing at a GBP review URL. Tracks send + click for conversion analysis.
model ReviewRequest {
  id            String    @id @default(cuid())
  // Recipient — phone OR email is required
  phone         String?
  email         String?
  recipientName String?
  // Source attribution
  sourceType    String? // "manual_paste" | "stripe_customer" | "lead" | "deal"
  sourceId      String?
  // Where the click goes
  gbpKey        String // "your_kc_homes" | "treasure_haul" | etc — keys defined in lib/reviews/gbps.ts
  shortCode     String    @unique // /go/r/<shortCode> redirect target
  // Lifecycle
  status        String    @default("queued") // queued | sent | clicked | bounced | failed
  channel       String // "sms" | "email"
  message       String?   @db.Text
  twilioSid     String?
  errorMessage  String?   @db.Text
  sentAt        DateTime?
  clickedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([gbpKey, status, createdAt])
  @@index([phone])
  @@index([email])
}

// Programmatic SEO neighborhood pages — generated via SerpAPI PAA + KG.
// Public route at /real-estate-agent/[slug].
model NeighborhoodPage {
  id                 String    @id @default(cuid())
  slug               String    @unique
  name               String // "Independence MO" | "Lee's Summit MO"
  city               String
  state              String
  zip                String?
  lat                Float?
  lng                Float?
  // Generated content
  intro              String?   @db.Text
  faqJson            Json? // [{question, answer}]
  relatedSearches    String[]  @default([])
  schoolsJson        Json? // {best, count, source}
  knowledgeGraphJson Json?
  // Lifecycle
  generatedAt        DateTime?
  published          Boolean   @default(false)
  serpapiQueriesUsed Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([state, city])
  @@index([published, generatedAt])
}

// Probate / estate-sale lead signals — discovered via obituary + court-record
// scraping, enriched with SerpAPI heir + property lookups, fed into the
// existing T-Agent dossier pipeline.
model ProbateSignal {
  id             String    @id @default(cuid())
  source         String // "legacy.com", "obittree.com", "casenet"
  sourceUrl      String?   @db.Text
  decedentName   String
  decedentAge    Int?
  obitDate       DateTime?
  city           String?
  state          String?
  county         String?
  zip            String?
  // Enrichment
  matchedAddress String?
  parcelId       String?
  estimatedValue Float?
  heirsJson      Json? // [{ name, relationship, profileUrl, source }]
  serpapiHits    Int       @default(0)
  // Lead lifecycle
  leadId         String? // FK to existing Lead model when promoted
  status         String    @default("discovered") // discovered | enriched | promoted | dismissed
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([source, sourceUrl])
  @@index([status, createdAt])
  @@index([decedentName])
  @@index([city, state])
}

// Distress Lead Engine — weekly SerpAPI google + google_news scan for
// highest-intent motivated-seller signals: pre-foreclosure / trustee &
// sheriff sale notices, tax-delinquency lists, and code-violation /
// dangerous-building dockets. Each hit is a candidate Cordless reviews; the
// scan PUSHES new rows to Telegram/email so leads come to him, not the other
// way around. Owner/address are best-effort guesses parsed from the snippet;
// promoted rows seed a Lead + the (now live) dossier owner-lookup pipeline.
model DistressSignal {
  id           String   @id @default(cuid())
  kind         String // foreclosure | tax-sale | sheriff-sale | code-violation
  source       String // host the notice was found on
  sourceUrl    String?  @db.Text
  title        String   @db.Text
  snippet      String?  @db.Text
  addressGuess String?
  ownerGuess   String?
  city         String?
  county       String?
  state        String?
  leadId       String? // FK to Lead when promoted
  status       String   @default("new") // new | reviewed | promoted | dismissed
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([source, sourceUrl])
  @@index([status, createdAt])
  @@index([kind, createdAt])
  @@index([city, state])
}

// ────────────────────────────────────────────────────────────────────────────
// RoutineBrief — output sink for Claude Code cloud "/schedule" routines.
// Each scheduled cloud agent POSTs its finished brief here (x-sync-secret auth),
// where it is stored, surfaced in /admin/routines, and fanned out to the Pulse
// Discord channel. Routines also email digiegold@ directly via the Gmail
// connector, so SMTP fan-out here is opt-in (?email=1) to avoid double sends.
// ────────────────────────────────────────────────────────────────────────────
model RoutineBrief {
  id        String    @id @default(cuid())
  slug      String // routine identifier, e.g. "revenue-health", "lead-followups"
  title     String
  body      String    @db.Text // markdown
  severity  String    @default("info") // info | action | alert
  payload   Json? // optional structured data (drafts, line items, links)
  readAt    DateTime?
  emailedAt DateTime? // set when included in a daily digest email (null = pending)
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@index([slug, createdAt])
  @@index([readAt])
  @@index([emailedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Growth HQ CRM — pipeline of scraped local-business prospects for the
// approved growth plan (sites / automation / delivery / video offers).
// Leads are imported via POST /api/hq/import (SerpAPI scrape output),
// move through stages on the /hq board, and outreach drafts queue up as
// GrowthTouch rows for 1-click approval. A separate sender cron picks up
// status=approved touches — nothing in /hq sends anything itself.
// ────────────────────────────────────────────────────────────────────────────
model GrowthLead {
  id            String        @id @default(cuid())
  name          String
  offer         String // "site" | "automation" | "delivery" | "video"
  category      String?
  address       String?
  city          String?
  phone         String?
  email         String?
  emailSource   String? // apollo | scraped | manual
  ownerName     String?
  website       String?
  websiteScore  Int?
  websiteNotes  String?
  rating        Float?
  reviews       Int?
  placeId       String?       @unique
  stage         String        @default("scraped") // scraped|enriched|demo_built|contacted|replied|booked|client|dead
  score         Int?
  demoUrl       String?
  videoUrl      String? // public watch-page path, e.g. /v/<slug>
  videoAssetUrl String? // Vercel Blob mp4 URL backing the watch page
  source        String        @default("serpapi")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  touches       GrowthTouch[]

  @@index([stage])
  @@index([offer, stage])
  @@index([createdAt])
}

model GrowthTouch {
  id        String     @id @default(cuid())
  leadId    String
  lead      GrowthLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel   String // email | sms | call | demo | note
  direction String     @default("out") // out | in
  status    String     @default("draft") // draft | approved | sent | received | discarded
  subject   String?
  body      String?
  meta      Json?
  createdAt DateTime   @default(now())
  sentAt    DateTime?

  @@index([status])
  @@index([leadId, createdAt])
}

/// DB-backed rate limiting + lightweight locks (no Redis in stack).
/// One row per (scope) key; consumed atomically via raw upsert in lib/rate-limit.ts.
model RateLimitBucket {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
}

/// KC Motivated Seller Digest — self-serve $199/mo (founding) / $299/mo agent
/// subscription. Replaces the v1 hardcoded list in lib/leads/digest-subscribers.ts.
/// Rows are created pending by /api/leads/digest/subscribe and flipped active
/// by the Stripe webhook (lib/digest-subscription.ts). The Monday digest cron
/// reads status in [active, trial].
model DigestSubscriber {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  farmZips             String[]
  status               String   @default("pending") // pending|active|trial|paused|canceled
  licenseState         String? // MO | KS
  licenseNumber        String?
  licenseStatus        String   @default("unverified") // unverified|verified|manual_review|invalid
  licenseeName         String? // name as the state registry has it
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  customScriptTemplate String?
  unsubscribeToken     String   @unique @default(cuid())
  joinedAt             DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
}

// Mileage tracking for IRS-compliant business-mileage deduction (MileIQ import)
model MileageTrip {
  id         String   @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  category   String // Business | Personal | Medical | Moving | Charity | Commute
  purpose    String? // MileIQ sub-purpose: Business, Airport/Travel, Errand/Supplies, Personal...
  startAddr  String
  stopAddr   String
  rate       Float    @default(0)
  miles      Float
  milesValue Float    @default(0)
  parking    Float    @default(0)
  tolls      Float    @default(0)
  total      Float    @default(0)
  vehicle    String   @default("CarPlay")
  notes      String?
  year       Int
  // dedupe key: startDate|stopAddr|miles  -> stable across re-imports
  dedupeKey  String   @unique
  createdAt  DateTime @default(now())

  @@index([year])
  @@index([category])
  @@index([startDate])
}

// ── Tolley Estate Sales ──────────────────────────────────────────────
// One row per estate sale event. Powers /estate + /estate/sales/[slug],
// the address-release cron (vipNotifyAt → email blast to estate-alerts
// list), and the past-sales social proof section. Address stays private
// until addressPublishAt per industry convention.
model EstateSale {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  areaLabel        String // public label, e.g. "Independence, MO"
  address          String? // private until addressPublishAt
  addressPublishAt DateTime? // public reveal (convention: 9am day before)
  vipNotifyAt      DateTime? // email-list reveal (night before the public)
  vipNotifiedAt    DateTime? // stamp set by the cron after the blast
  announcedAt      DateTime? // stamp set by the cron after the new-sale teaser blast (no address)
  days             Json // [{date:"2026-07-17",open:"08:00",close:"16:00",note?}]
  startsAt         DateTime
  endsAt           DateTime
  status           String    @default("upcoming") // upcoming|live|done
  description      String?
  highlights       String[]
  photos           String[]
  photosUpdatedAt  DateTime? // last time the gallery changed — shown as "Updated …"
  videoUrl         String? // walkthrough video (blob URL), shown atop the gallery
  grossTotal       Float?
  checklist        Json? // per-sale playbook checkboxes (ESTATE-PLAYBOOK §5), e.g. {esn:true,...}
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  leads            EstateLead[]

  @@index([status, startsAt])
}

/// Estate seller-lead pipeline (families who need a sale run) — /hq Estates tab.
/// Separate from GrowthLead: the seller journey (inquiry→walkthrough→signed→
/// scheduled→done|lost) doesn't fit the B2B board stages. B2B referral partners
/// (attorneys etc.) live in GrowthLead with offer "estate" instead.
model EstateLead {
  id            String      @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  city          String      @default("Independence")
  source        String      @default("manual") // inbound|circle|referral|fb|esn|probate|manual
  stage         String      @default("inquiry") // inquiry|walkthrough|signed|scheduled|done|lost
  notes         String?     @db.Text
  walkthroughAt DateTime?
  saleId        String?
  sale          EstateSale? @relation(fields: [saleId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([stage])
  @@index([createdAt])
}

// ── YouTube channel analytics (/hq Stats tab) ────────────────────────
// Daily snapshots pulled by /api/cron/youtube-stats from the YouTube Data +
// Analytics APIs (channel @yourkchome). `pipeline` attributes each video to
// the DGX pipeline that made it; the DGX pushes that map via
// POST /api/hq/stats/videos (x-sync-secret).
model YouTubeVideo {
  videoId     String             @id
  title       String
  publishedAt DateTime
  durationSec Int?
  pipeline    String             @default("other") // shorts|housing|listings|estate|other
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  stats       YouTubeVideoStat[]
}

model YouTubeVideoStat {
  id                      String       @id @default(cuid())
  videoId                 String
  video                   YouTubeVideo @relation(fields: [videoId], references: [videoId], onDelete: Cascade)
  day                     DateTime // snapshot date (UTC midnight)
  views                   Int          @default(0)
  likes                   Int          @default(0)
  comments                Int          @default(0)
  estimatedMinutesWatched Float?
  avgViewDurationSec      Float?
  avgViewPct              Float?
  subsGained              Int?
  impressions             Int? // not exposed by the Analytics API — stays null (UI shows n/a)
  ctr                     Float? // same caveat
  pulledAt                DateTime     @default(now())

  @@unique([videoId, day])
  @@index([day])
}

/// One-click "Analyze" recaps generated in the /hq Stats tab (Gemini).
model HqStatsAnalysis {
  id        String   @id @default(cuid())
  markdown  String   @db.Text
  inputHash String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ── Deep Research Search ─────────────────────────────────────────────
// One row per research question submitted at /research. Two-lane model:
// Lane 1 answers instantly from completed rows (exact queryNormalized
// match, later Qdrant semantic match); Lane 2 submits the question to
// OpenManus on the DGX and live-polls progress. Mirrors DossierJob's
// live-polling fields (progress/currentPhase/stepDetails).
model ResearchJob {
  id              String    @id @default(cuid())
  query           String
  queryNormalized String // lowercase/trim/collapsed whitespace — Lane-1 exact match key
  status          String    @default("queued") // queued|submitted|running|verifying|completed|failed
  progress        Int       @default(0)
  currentPhase    String? // searching|reading|verifying|scoring|done
  currentStep     String? // human label, e.g. "Reading sources (3/8)"
  stepDetails     Json? // [{i, tool, label, at}] parsed from Manus steps
  manusTaskId     String?
  verifyTaskId    String?
  etaSeconds      Int?
  confidence      Int? // final 0-100, capped by verification verdicts
  result          Json? // {answerMarkdown, claims:[{text, sources:[{url,title,quote}], verified, confidence}], overallConfidence, unverifiedNotes}
  errorMessage    String?
  cacheHits       Int       @default(0)
  qdrantPointId   String?
  requestedBy     String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([queryNormalized, status])
}
