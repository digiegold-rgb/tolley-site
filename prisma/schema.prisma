generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String?            @unique
  emailVerified        DateTime?
  image                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  subscriptionStatus   String             @default("none")
  subscriptionTier     String             @default("none")
  currentPeriodEnd     DateTime?
  accounts             Account[]
  agents               Agent[]
  credentialAuth       CredentialAuth?
  deliveryClient       DeliveryClient?
  deliveryDriver       DeliveryDriver?
  foodFamilyMembers    FoodFamilyMember[]
  foodHousehold        FoodHousehold?
  leadSubscription     LeadSubscriber?
  mfaBackupCodes       MfaBackupCode[]
  savedResults         SavedResult[]
  sessions             Session[]
  subscription         Subscription?
  usageBuckets         UsageBucket[]
  usageEvents          UsageEvent[]
  mfa                  UserMfa?
  videoCredit          VideoCredit?
  videoGenerations     VideoGeneration[]
}

model Agent {
  id            String   @id @default(cuid())
  userId        String
  name          String
  rolePurpose   String
  modelProvider String
  systemPrompt  String
  toolsEnabled  String[]
  webhookUrl    String?
  phoneBinding  String?
  emailBinding  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model SavedResult {
  id          String   @id @default(cuid())
  userId      String
  query       String
  title       String
  contentJson Json
  contentText String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CredentialAuth {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  status               String
  priceId              String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id               String   @id @default(cuid())
  userId           String?
  type             String
  createdAt        DateTime @default(now())
  tokensApprox     Int?
  requestId        String?
  latencyMs        Int?
  completionTokens Int?
  endpoint         String?
  errorMessage     String?
  location         String?
  meta             Json?
  model            String?
  promptTokens     Int?
  provider         String?
  route            String?
  statusCode       Int?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@index([model, createdAt])
  @@index([type, createdAt])
}

model UsageBucket {
  id           String   @id @default(cuid())
  userId       String
  bucketDate   DateTime
  countAsks    Int      @default(0)
  countMinutes Int      @default(0)
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bucketDate])
  @@index([userId, lastSeenAt])
}

model ShopItem {
  id          String    @id @default(cuid())
  title       String
  price       Float
  description String?
  category    String?
  imageUrls   String[]
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  soldAt      DateTime?

  @@index([status, createdAt])
}

model McpInvocation {
  id        String   @id @default(cuid())
  tool      String
  input     Json?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tool, createdAt])
}

model Listing {
  id                String             @id @default(cuid())
  mlsId             String             @unique
  status            String
  listPrice         Float?
  originalListPrice Float?
  address           String
  city              String?
  state             String?            @default("MO")
  zip               String?
  beds              Int?
  baths             Float?
  sqft              Int?
  propertyType      String?
  daysOnMarket      Int?
  onMarketDate      DateTime?
  closeDate         DateTime?
  listingUrl        String?
  photoUrls         String[]
  listAgentName     String?
  listAgentMlsId    String?
  listOfficeName    String?
  listOfficeMlsId   String?
  rawData           Json?
  lastSynced        DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lat               Float?
  lng               Float?
  source            String?            @default("mls")
  Deal              Deal[]
  dossierJobs       DossierJob[]
  leads             Lead[]
  enrichment        ListingEnrichment?
  parcel            Parcel?

  @@index([status, zip])
  @@index([status, daysOnMarket])
  @@index([status, city])
  @@index([lastSynced])
}

model Lead {
  id             String        @id @default(cuid())
  listingId      String?
  score          Int           @default(0)
  scoreFactors   Json?
  status         String        @default("new")
  ownerName      String?
  ownerPhone     String?
  ownerEmail     String?
  notes          String?
  source         String?
  referredTo     String?
  referralStatus String?
  referralFee    Float?
  contactedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  parcelId       String?
  pipelineOrder  Int           @default(0)
  pipelineStage  String        @default("new_lead")
  ContactTag     ContactTag[]
  CrmActivity    CrmActivity[]
  CrmTask        CrmTask[]
  Deal           Deal[]
  listing        Listing?      @relation(fields: [listingId], references: [id])
  parcel         Parcel?       @relation(fields: [parcelId], references: [id])

  @@index([status, score])
  @@index([source, createdAt])
  @@index([referralStatus])
  @@index([parcelId])
  @@index([pipelineStage, pipelineOrder])
  @@index([score(sort: Desc), createdAt(sort: Desc)], map: "Lead_score_desc_createdAt_desc_idx")
}

model PointOfInterest {
  id        String   @id @default(cuid())
  osmId     String?  @unique
  type      String
  name      String?
  lat       Float
  lng       Float
  tags      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([type, lat, lng])
}

model ListingEnrichment {
  id                     String   @id @default(cuid())
  listingId              String   @unique
  nearestSchoolDist      Float?
  nearestSchoolName      String?
  schoolsWithin3mi       Int?
  nearestHospitalDist    Float?
  nearestHospitalName    String?
  nearestFireStationDist Float?
  nearestPoliceDist      Float?
  nearestParkDist        Float?
  nearestParkName        String?
  parksWithin2mi         Int?
  nearestGroceryDist     Float?
  nearestGroceryName     String?
  nearestMallDist        Float?
  nearestAirportDist     Float?
  nearestAirportName     String?
  nearestSportsDist      Float?
  restaurantsWithin1mi   Int?
  buyScore               Int      @default(0)
  buyScoreFactors        Json?
  enrichedAt             DateTime @default(now())
  assessedValue          Float?
  assessmentRatio        Float?
  countyFips             String?
  countyName             String?
  countyState            String?
  effectiveTaxRate       Float?
  estimatedAnnualTax     Float?
  estimatedMonthlyTax    Float?
  levyPer100             Float?
  librariesWithin3mi     Int?
  nearestCourthouseDist  Float?
  nearestCourthouseName  String?
  nearestLibraryDist     Float?
  nearestLibraryName     String?
  taxBurdenRating        String?
  listing                Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([buyScore])
  @@index([countyName])
  @@index([taxBurdenRating])
}

model LeadSubscriber {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tier                 String   @default("starter")
  stripeSubscriptionId String?  @unique
  status               String   @default("active")
  farmZips             String[]
  farmCities           String[]
  specialties          String[]
  smsLimit             Int      @default(50)
  smsUsed              Int      @default(0)
  maxAgents            Int      @default(1)
  onboarded            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  snapLimit            Int      @default(0)
  snapUsed             Int      @default(0)
  dailyContactGoal     Int      @default(10)
  referralFeesEarned   Float    @default(0)
  referralFeesPending  Float    @default(0)
  weeklyDigestEnabled  Boolean  @default(true)
  fundScanLimit        Int      @default(0)
  fundScanUsed         Int      @default(0)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tier])
}

model EmailLead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String // "calculator", "audit", "newsletter", "resource", "market-analysis"
  data      Json? // tool results, preferences, etc.
  tags      String[]
  optedIn   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([createdAt])
}

model SmsConversation {
  id            String       @id @default(cuid())
  phoneNumber   String
  businessId    String?
  subscriberId  String?
  leadId        String?
  systemPrompt  String?
  status        String       @default("active")
  messageCount  Int          @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  messages      SmsMessage[]

  @@unique([phoneNumber, businessId])
  @@index([subscriberId])
  @@index([status, lastMessageAt])
}

model SmsMessage {
  id             String          @id @default(cuid())
  conversationId String
  direction      String
  body           String
  mediaUrls      String[]
  twilioSid      String?         @unique
  status         String          @default("sent")
  tokensUsed     Int?
  createdAt      DateTime        @default(now())
  conversation   SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model DossierBatch {
  id            String       @id @default(cuid())
  name          String?
  source        String       @default("csv")
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  failedRows    Int          @default(0)
  status        String       @default("pending")
  userId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  jobs          DossierJob[]

  @@index([userId])
  @@index([status])
}

model DossierJob {
  id             String         @id @default(cuid())
  listingId      String
  leadId         String?
  status         String         @default("queued")
  progress       Int            @default(0)
  currentStep    String?
  stepsCompleted String[]
  stepsFailed    String[]
  errorMessage   String?
  requestedBy    String?
  priority       Int            @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  batchId        String?
  // Per-step execution detail: { [stepName]: { status, error?, warnings?, durationMs?, startedAt?, finishedAt?, tier? } }
  // Populated incrementally during pipeline execution so live-polling UI can show real-time state.
  stepDetails    Json?
  // Which overall phase the pipeline is in: "health_check" | "research_worker" | "local_plugins" | "aggregating" | "done"
  currentPhase   String?
  batch          DossierBatch?  @relation(fields: [batchId], references: [id])
  listing        Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  result         DossierResult?

  @@index([status, priority])
  @@index([listingId])
  @@index([batchId])
  @@index([createdAt])
}

model DossierResult {
  id                 String     @id @default(cuid())
  jobId              String     @unique
  owners             Json?
  entityType         String?
  entityName         String?
  courtCases         Json?
  liens              Json?
  bankruptcies       Json?
  taxRecords         Json?
  deedHistory        Json?
  socialProfiles     Json?
  webMentions        Json?
  relatedPeople      Json?
  streetViewUrl      String?
  satelliteUrl       String?
  neighborhoodPhotos String[]
  motivationScore    Int?
  motivationFlags    String[]
  researchSummary    String?
  pluginData         Json?
  neighborhoodData   Json?
  financialData      Json?
  permitData         Json?
  rentalData         Json?
  businessData       Json?
  environmentalData  Json?
  marketData         Json?
  customData         Json?
  // Long-form investment narrative synthesized by OpenManus after all plugins
  // finish. Written by `lib/dossier/synthesis.ts` as a post-aggregation step.
  // Null if the synthesis call timed out, errored, or OpenManus was unreachable.
  narrativeReport    String?
  // Per-task metadata from the Manus run: task id, step count, source tags.
  // Allows operators to look up the original Manus task in its RAG record.
  narrativeMeta      Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  job                DossierJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([motivationScore])
}

model PipelineWorkflow {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("Default Pipeline")
  description String?
  nodes       Json
  edges       Json
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}

model Client {
  id                     String         @id @default(cuid())
  subscriberId           String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  facebookUrl            String?
  instagramUrl           String?
  linkedinUrl            String?
  twitterUrl             String?
  tiktokUrl              String?
  buyerSeller            String         @default("buyer")
  preApproved            Boolean        @default(false)
  preApprovalAmount      Float?
  minPrice               Float?
  maxPrice               Float?
  minBeds                Int?
  maxBeds                Int?
  minBaths               Float?
  minSqft                Int?
  maxSqft                Int?
  preferredCities        String[]
  preferredZips          String[]
  preferredPropertyTypes String[]
  moveTimeline           String?
  currentCity            String?
  currentState           String?
  movingFrom             String?
  birthday               String?
  household              String?
  kids                   Int?
  pets                   String?
  occupation             String?
  interests              String[]
  dealbreakers           String[]
  fitScore               Int            @default(0)
  fitScoreFactors        Json?
  status                 String         @default("active")
  avatarUrl              String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  jobTitle               String?
  employer               String?
  industry               String?
  educationLevel         String?
  estimatedIncome        Float?
  incomeRangeLow         Float?
  incomeRangeHigh        Float?
  incomeSource           String?
  incomeConfidence       String?
  incomeEstimatedAt      DateTime?
  estimatedMaxHome       Float?
  affordabilityData      Json?
  discType               String?
  discSecondary          String?
  discAssessment         Json?
  readinessScore         Int            @default(0)
  readinessFactors       Json?
  clientMatches          ClientMatch[]
  notes                  ClientNote[]
  ContactTag             ContactTag[]
  CrmActivity            CrmActivity[]
  CrmTask                CrmTask[]
  Deal                   Deal[]
  triggerEvents          TriggerEvent[]

  @@index([subscriberId, status])
  @@index([fitScore])
  @@index([readinessScore])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  category  String   @default("general")
  content   String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model TriggerEvent {
  id         String   @id @default(cuid())
  clientId   String
  type       String
  strength   String?
  details    String?
  occurredAt DateTime @default(now())
  source     String?
  createdAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, occurredAt])
  @@index([type])
}

model ClientMatch {
  id           String   @id @default(cuid())
  clientId     String
  listingId    String
  matchScore   Int      @default(0)
  matchFactors Json?
  direction    String   @default("client_to_listing")
  computedAt   DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, listingId, direction])
  @@index([matchScore])
}

model JjPageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([referrer, createdAt])
}

model JjPhoneClick {
  id        String   @id @default(cuid())
  referrer  String?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([referrer])
}

model SiteView {
  id        String   @id @default(cuid())
  site      String
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  ipHash    String?
  country   String?
  region    String?
  city      String?
  createdAt DateTime @default(now())

  @@index([site, createdAt])
  @@index([createdAt])
  @@index([referrer, createdAt])
  @@index([ipHash, createdAt])
  @@index([country, createdAt])
}

model SiteEvent {
  id        String   @id @default(cuid())
  site      String
  path      String
  event     String
  label     String?
  referrer  String?
  userAgent String?
  ip        String?
  ipHash    String?
  country   String?
  region    String?
  city      String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([site, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
  @@index([ipHash, createdAt])
}

model SnapRequest {
  id              String   @id @default(cuid())
  userId          String
  photoUrl        String
  photoExifLat    Float?
  photoExifLng    Float?
  browserLat      Float?
  browserLng      Float?
  manualAddress   String?
  resolvedLat     Float?
  resolvedLng     Float?
  resolvedAddress String?
  resolvedCity    String?
  resolvedState   String?
  resolvedZip     String?
  resolvedCounty  String?
  listingId       String?
  dossierJobId    String?
  status          String   @default("pending")
  errorMessage    String?
  estimatedEquity Float?
  equityBreakdown Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model AutoResponder {
  id              String   @id @default(cuid())
  subscriberId    String
  name            String   @default("Default")
  isActive        Boolean  @default(true)
  triggerSource   String[]
  minScore        Int      @default(30)
  promptId        String   @default("speed_to_lead_seller")
  delaySeconds    Int      @default(30)
  maxPerDay       Int      @default(20)
  sentToday       Int      @default(0)
  notifyPhone     String?
  notifyEmail     String?
  notifyMinScore  Int      @default(60)
  activeStartHour Int      @default(9)
  activeEndHour   Int      @default(20)
  timezone        String   @default("America/Chicago")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subscriberId, isActive])
}

model ActivityLog {
  id             String   @id @default(cuid())
  subscriberId   String
  activityDate   DateTime @db.Date
  contactsMade   Int      @default(0)
  followUpsSent  Int      @default(0)
  newLeads       Int      @default(0)
  dossiersRun    Int      @default(0)
  smsSent        Int      @default(0)
  smsReplies     Int      @default(0)
  leadsContacted Int      @default(0)
  leadsConverted Int      @default(0)
  dailyGoal      Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([subscriberId, activityDate])
}

model SmsSequence {
  id           String            @id @default(cuid())
  subscriberId String
  name         String
  description  String?
  isActive     Boolean           @default(true)
  targetSource String[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  enrollments  SmsEnrollment[]
  steps        SmsSequenceStep[]

  @@index([subscriberId, isActive])
}

model SmsSequenceStep {
  id            String      @id @default(cuid())
  sequenceId    String
  stepNumber    Int
  delayDays     Int
  delayHours    Int         @default(0)
  promptId      String?
  templateBody  String?
  isAiGenerated Boolean     @default(true)
  createdAt     DateTime    @default(now())
  sequence      SmsSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
}

model SmsEnrollment {
  id             String      @id @default(cuid())
  sequenceId     String
  leadId         String?
  phoneNumber    String
  conversationId String?
  currentStep    Int         @default(0)
  status         String      @default("active")
  nextSendAt     DateTime?
  enrolledAt     DateTime    @default(now())
  completedAt    DateTime?
  updatedAt      DateTime    @updatedAt
  sequence       SmsSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([status, nextSendAt])
  @@index([phoneNumber])
}

model SyncLog {
  id             String   @id @default(cuid())
  source         String
  recordsTotal   Int      @default(0)
  recordsNew     Int      @default(0)
  recordsUpdated Int      @default(0)
  duration       Int?
  error          String?
  createdAt      DateTime @default(now())

  @@index([source, createdAt])
}

model Parcel {
  id                 String   @id @default(cuid())
  regridId           String   @unique
  parcelnumb         String?
  address            String
  city               String?
  state              String?
  zip                String?
  county             String?
  lat                Float?
  lng                Float?
  owner              String?
  owntype            String?
  ownfrst            String?
  ownlast            String?
  mailadd            String?
  mailcity           String?
  mailstate          String?
  mailzip            String?
  isAbsentee         Boolean  @default(false)
  isVacant           Boolean  @default(false)
  parval             Float?
  landval            Float?
  improvval          Float?
  saleprice          Float?
  saledate           String?
  taxamt             Float?
  yearbuilt          Int?
  numstories         Float?
  numunits           Int?
  num_bedrooms       Int?
  num_bath           Float?
  struct             String?
  ll_gisacre         Float?
  ll_gissqft         Float?
  zoning             String?
  zoning_description String?
  usps_vacancy       String?
  qoz                Boolean  @default(false)
  rawData            Json?
  geometry           Json?
  listingId          String?  @unique
  regridFetchedAt    DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  leads              Lead[]
  listing            Listing? @relation(fields: [listingId], references: [id])

  @@index([zip])
  @@index([county])
  @@index([owner])
  @@index([isAbsentee, isVacant])
  @@index([parcelnumb])
  @@index([lat, lng])
}

model NarrprImport {
