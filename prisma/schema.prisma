// ─── Unclaimed Funds Discovery ──────────────────────────────

model UnclaimedFundScan {
  id              String           @id @default(cuid())
  subscriberId    String?          // LeadSubscriber who initiated
  userId          String
  // Search params
  ownerName       String           // primary name searched
  alternateNames  String[]         // aliases, maiden names, etc.
  sources         String[]         // mo_unclaimed, mo_tax_surplus, ks_unclaimed, pa_unclaimed, hud, fdic, missingmoney
  // Pipeline links (optional — bridges dossier integration)
  listingId       String?
  dossierJobId    String?
  // Results
  status          String           @default("pending") // pending, running, complete, partial, failed
  totalFound      Int              @default(0)
  claimableAmount Float            @default(0)
  errorMessage    String?
  duration        Int?             // ms
  // Relations
  funds           UnclaimedFund[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([subscriberId])
  @@index([status])
  @@index([ownerName])
  @@index([createdAt])
}

model UnclaimedFund {
  id              String               @id @default(cuid())
  scanId          String
  scan            UnclaimedFundScan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  // Fund details
  source          String               // mo_unclaimed, mo_tax_surplus, ks_unclaimed, etc.
  externalId      String?              // ID from the source system (for dedup)
  amount          Float?               // reported amount (null if not disclosed)
  ownerName       String               // name as it appears in the source
  holderName      String?              // entity holding the funds (bank, county, state)
  propertyType    String?              // cash, stock, insurance, safe_deposit, tax_surplus
  reportDate      DateTime?            // when funds were reported/escheated
  lastActivityDate DateTime?           // last known activity on the account
  address         String?              // address associated with the funds
  city            String?
  state           String?
  zip             String?
  // Matching
  matchConfidence Float                @default(0) // 0-1
  matchMethod     String?              // exact, fuzzy, alias
  // Raw data from scraper
  rawData         Json?
  // Claim link
  claim           UnclaimedFundClaim?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([source, externalId])
  @@index([scanId])
  @@index([ownerName])
  @@index([amount])
  @@index([source])
}

model UnclaimedFundClaim {
  id              String          @id @default(cuid())
  fundId          String          @unique
  fund            UnclaimedFund   @relation(fields: [fundId], references: [id], onDelete: Cascade)
  subscriberId    String
  // Status workflow
  status          String          @default("identified") // identified, contacted, agreement_signed, filed, approved, paid
  // Compliance
  jurisdiction    String          // MO, KS, PA, federal
  sourceType      String          // state_unclaimed, tax_surplus, hud, fdic
  waitingPeriodEnd DateTime?      // null = no waiting period or unknown
  maxFeePercent   Float?          // computed from compliance engine
  currentFeeWindow String?        // e.g. "12-24mo: 10%", "36+: 20%"
  claimDeadline   DateTime?       // hard deadline if applicable
  statuteReference String?        // e.g. "RSMo 447.581"
  complianceWarnings String[]     // any warnings from compliance engine
  // Financials
  claimAmount     Float?          // amount being claimed
  agreedFeePercent Float?         // fee agreed with owner
  expectedFee     Float?          // claimAmount * agreedFeePercent
  actualPayout    Float?          // what was actually received
  // Outreach
  ownerPhone      String?
  ownerEmail      String?
  ownerAddress    String?
  contactAttempts Int             @default(0)
  lastContactAt   DateTime?
  agreementSignedAt DateTime?
  // Filing
  filedAt         DateTime?
  approvedAt      DateTime?
  paidAt          DateTime?
  // Notes
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([subscriberId])
  @@index([status])
  @@index([jurisdiction])
  @@index([waitingPeriodEnd])
}

// ─── Multi-Channel Content & Outreach Engine ────────────────

model PlatformConnection {
  id                  String    @id @default(cuid())
  subscriberId        String
  platform            String    // linkedin, twitter, facebook, instagram, youtube, tiktok
  platformAccountId   String    // platform-specific user/page ID
  platformUsername    String?
  accessToken         String    // encrypted at rest via env
  refreshToken        String?
  tokenExpiresAt      DateTime?
  scopes              String[]
  pageId              String?   // for FB Pages, LinkedIn Orgs
  pageName            String?
  status              String    @default("active") // active, expired, revoked, error
  lastError           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([subscriberId, platform, platformAccountId])
  @@index([subscriberId])
  @@index([status])
  @@index([tokenExpiresAt])
}

model ContentTemplate {
  id              String    @id @default(cuid())
  subscriberId    String?   // null = system default template
  name            String
  platform        String    // linkedin, twitter, facebook, instagram, youtube, tiktok, all
  category        String    // market_update, listing_promo, neighborhood_spotlight, seller_tip, buyer_guide, just_sold, open_house, personal_brand
  promptTemplate  String    // system prompt with {{variables}}
  bodyTemplate    String?   // optional static body
  hashtagStrategy Json?     // { count: 5, style: "trending" | "niche" | "branded" }
  mediaStrategy   Json?     // { type: "property_photo" | "infographic" | "none", count: 1 }
  tone            String    @default("professional") // professional, casual, authoritative, friendly
  isActive        Boolean   @default(true)
  posts           ContentPost[]
  campaigns       ContentCampaign[] @relation("CampaignTemplates")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([subscriberId])
  @@index([platform, category])
}

model ContentPost {
  id              String    @id @default(cuid())
  subscriberId    String
  platform        String    // linkedin, twitter, facebook, instagram, youtube, tiktok
  contentType     String    @default("text") // text, image, carousel, video, reel
  body            String
  mediaUrls       String[]
  hashtags        String[]
  // Source context
  templateId      String?
  template        ContentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  listingId       String?
  clientId        String?
  dossierJobId    String?
  aiPromptUsed    String?   // the actual prompt sent to LLM
  campaignId      String?
  campaign        ContentCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  // Schedule
  scheduledAt     DateTime?
  publishedAt     DateTime?
  // Platform response
  platformPostId  String?
  platformUrl     String?
  // Status: draft → scheduled → publishing → published → failed
  status          String    @default("draft")
  errorMessage    String?
  retryCount      Int       @default(0)
  // Engagement metrics
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  engagementRate  Float     @default(0)
  lastEngagementSync DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([subscriberId, status])
  @@index([status, scheduledAt])
  @@index([platform, publishedAt])
  @@index([campaignId])
}

model ContentCampaign {
  id              String    @id @default(cuid())
  subscriberId    String
  name            String
  description     String?
  platforms       String[]  // linkedin, twitter, etc.
  templateIds     String[]
  templates       ContentTemplate[] @relation("CampaignTemplates")
  frequency       String    @default("daily") // daily, weekdays, weekly, custom
  postsPerDay     Int       @default(1)
  preferredTimes  String[]  // ["09:00", "12:00", "17:00"]
  timezone        String    @default("America/Chicago")
  sourceType      String    @default("ai_generated") // ai_generated, template_fill
  sourceFilter    Json?     // { minScore: 30, status: ["new"], farmZips: ["64055"] }
  isActive        Boolean   @default(false)
  startDate       DateTime?
  endDate         DateTime?
  postsGenerated  Int       @default(0)
  postsPublished  Int       @default(0)
  posts           ContentPost[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([subscriberId, isActive])
  @@index([isActive])
}

