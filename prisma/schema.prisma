}

model CryptoPrediction {
  id            String   @id @default(cuid())
  asset         String
  direction     String
  targetPrice   Float
  confidence    Float
  rationale     String?
  source        String   @default("ai")
  currentPrice  Float
  actualPrice   Float?
  accuracy      Float?
  status        String   @default("pending")
  targetDate    DateTime
  gradedAt      DateTime?
  createdAt     DateTime @default(now())
  @@index([status, targetDate])
}

model CryptoWallet {
  id            String   @id @default(cuid())
  provider      String
  network       String   @default("base")
  address       String?
  balanceUsd    Float    @default(0)
  balances      Json?
  mode          String   @default("paper")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}
