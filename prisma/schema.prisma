model LeadSubscriber {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tier                 String   @default("starter")
  stripeSubscriptionId String?  @unique
  status               String   @default("active")
  farmZips             String[]
  farmCities           String[]
  specialties          String[]
  smsLimit             Int      @default(50)
  smsUsed              Int      @default(0)
  maxAgents            Int      @default(1)
  onboarded            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  snapLimit            Int      @default(0)
  snapUsed             Int      @default(0)
  dailyContactGoal     Int      @default(10)
  referralFeesEarned   Float    @default(0)
  referralFeesPending  Float    @default(0)
  weeklyDigestEnabled  Boolean  @default(true)
  fundScanLimit        Int      @default(0)
  fundScanUsed         Int      @default(0)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tier])
}

model EmailLead {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  source          String // "calculator", "audit", "newsletter", "resource", "market-analysis"
  data            Json? // tool results, preferences, etc.
  tags            String[]
  optedIn         Boolean   @default(true)
  // Triage workflow — surfaced in the /hq Inbox alongside LeadAction rows.
  status          String    @default("new")
  statusNote      String?
  statusUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

/// Transactional agent action submission. An AI agent (or HTTP client) calls
/// `submit_subsite_action` (MCP) or POST /api/lead/action with structured fields,
/// gets back a `receiptToken`, then can GET /api/lead/<token> for status.
/// Distinct from EmailLead (which is unique-per-email and used for "I want updates").
model LeadAction {
  id              String    @id @default(cuid())
  receiptToken    String    @unique
  subsite         String
  action          String
  email           String?
  name            String?
  phone           String?
  structured      Json?
  status          String    @default("new")
  statusNote      String?
  statusUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([subsite, action, createdAt])
  @@index([status, createdAt])
}

/// The Launchpad (tolley.io/sales) — a person Jared has taken on as an operator.
/// Created `pending` the moment a Work Order is submitted (instant preview site);
/// Jared flips the storefront live (`sellingEnabled`) after the handshake, which
/// sets status `approved`. `userId` links the claimed NextAuth login (plain
/// string, no FK, keeps the migration additive). `leadActionId` points back at
/// the originating intake row.
model Operator {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  email           String?
  phone           String?
  status          String      @default("pending") // pending | approved | paused | bought_out
  userId          String? // claimed NextAuth user id (no FK — additive)
  termsAcceptedAt DateTime?
  approvedAt      DateTime?
  leadActionId    String? // originating LeadAction (intake)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  storefront      Storefront?

  @@index([status, createdAt])
  @@index([userId])
}

/// The operator's public one-page storefront rendered at /biz/<slug>. Themed
/// via lib/demo-site.ts (`category` is a theme key). `sellingEnabled` is Jared's
/// kill-switch: Buy buttons stay locked until he approves. `offerings` is a JSON
/// array of {name, desc, priceCents, kind:"one_time"|"monthly"}.
model Storefront {
  id               String          @id @default(cuid())
  operatorId       String          @unique
  operator         Operator        @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  slug             String          @unique
  businessName     String
  category         String          @default("generic") // demo-site theme key
  tagline          String?
  about            String?
  city             String?
  phone            String?
  offerings        Json            @default("[]") // [{name, desc, priceCents, kind}]
  published        Boolean         @default(true)
  sellingEnabled   Boolean         @default(false) // Jared's gate
  stripeProductIds Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  sales            LaunchpadSale[]

  @@index([published, createdAt])
}

/// A completed sale through an operator's storefront (webhook-filled from the
/// Stripe checkout.session.completed with metadata.product="launchpad").
model LaunchpadSale {
  id              String     @id @default(cuid())
  storefrontId    String
  storefront      Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  offeringName    String
  amountCents     Int
  kind            String // one_time | monthly
  stripeSessionId String     @unique
  buyerEmail      String?
  buyerName       String?
  buyerPhone      String?
  createdAt       DateTime   @default(now())

  @@index([storefrontId, createdAt])
}

/// Auto-minted share link for any subsite. Distinct from /go (hand-curated promo redirects).
/// `/s/<token>` → 302 to `path` with `?ref=share&t=<token>`. Tracks click attribution per subsite.
model ShareLink {
  id            String    @id @default(cuid())
  token         String    @unique
  subsite       String
  path          String
  title         String?
  createdById   String?
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt     DateTime?
  clickCount    Int       @default(0)
  lastClickedAt DateTime?
  meta          Json?
  createdAt     DateTime  @default(now())

  @@index([subsite, createdAt])
  @@index([createdById])
}

model SmsConversation {
  id            String       @id @default(cuid())
  phoneNumber   String
  businessId    String?
  subscriberId  String?
  leadId        String?
  systemPrompt  String?
  status        String       @default("active")
  messageCount  Int          @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  messages      SmsMessage[]

  @@unique([phoneNumber, businessId])
  @@index([subscriberId])
  @@index([status, lastMessageAt])
}

model SmsMessage {
  id             String          @id @default(cuid())
  conversationId String
  direction      String
  body           String
  mediaUrls      String[]
  twilioSid      String?         @unique
  status         String          @default("sent")
  tokensUsed     Int?
  createdAt      DateTime        @default(now())
  conversation   SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model DossierBatch {
  id            String       @id @default(cuid())
  name          String?
  source        String       @default("csv")
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  failedRows    Int          @default(0)
  status        String       @default("pending")
  userId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  jobs          DossierJob[]

  @@index([userId])
  @@index([status])
}

model DossierJob {
  id             String         @id @default(cuid())
  listingId      String
  leadId         String?
  status         String         @default("queued")
  progress       Int            @default(0)
  currentStep    String?
  stepsCompleted String[]
  stepsFailed    String[]
  errorMessage   String?
  requestedBy    String?
  priority       Int            @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  batchId        String?
  // Per-step execution detail: { [stepName]: { status, error?, warnings?, durationMs?, startedAt?, finishedAt?, tier? } }
  // Populated incrementally during pipeline execution so live-polling UI can show real-time state.
  stepDetails    Json?
  // Which overall phase the pipeline is in: "health_check" | "research_worker" | "local_plugins" | "aggregating" | "done"
  currentPhase   String?
  batch          DossierBatch?  @relation(fields: [batchId], references: [id])
  listing        Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  result         DossierResult?

  @@index([status, priority])
  @@index([listingId])
  @@index([batchId])
  @@index([createdAt])
}

model DossierResult {
  id                 String     @id @default(cuid())
  jobId              String     @unique
  owners             Json?
  entityType         String?
  entityName         String?
  courtCases         Json?
  liens              Json?
  bankruptcies       Json?
  taxRecords         Json?
  deedHistory        Json?
  socialProfiles     Json?
  webMentions        Json?
  relatedPeople      Json?
  streetViewUrl      String?
  satelliteUrl       String?
  neighborhoodPhotos String[]
  motivationScore    Int?
  motivationFlags    String[]
  researchSummary    String?
  pluginData         Json?
  neighborhoodData   Json?
  financialData      Json?
  permitData         Json?
  rentalData         Json?
  businessData       Json?
  environmentalData  Json?
  marketData         Json?
  customData         Json?
  // Long-form investment narrative synthesized by OpenManus after all plugins
  // finish. Written by `lib/dossier/synthesis.ts` as a post-aggregation step.
  // Null if the synthesis call timed out, errored, or OpenManus was unreachable.
  narrativeReport    String?
  // Per-task metadata from the Manus run: task id, step count, source tags.
  // Allows operators to look up the original Manus task in its RAG record.
  narrativeMeta      Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  job                DossierJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([motivationScore])
}

model PipelineWorkflow {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("Default Pipeline")
  description String?
  nodes       Json
  edges       Json
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}

