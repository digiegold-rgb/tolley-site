  source         String   // mls_grid, propstream, regrid
  recordsTotal   Int      @default(0)
  recordsNew     Int      @default(0)
  recordsUpdated Int      @default(0)
  duration       Int?     // ms
  error          String?
  createdAt      DateTime @default(now())

  @@index([source, createdAt])
}

// ─── Regrid Parcel Data (Off-Market Property Intelligence) ──

model Parcel {
  id                    String    @id @default(cuid())
  // Regrid identifiers
  regridId              String    @unique  // Regrid's internal feature ID
  parcelnumb            String?            // Assessor Parcel Number (APN)
  // Address
  address               String
  city                  String?
  state                 String?
  zip                   String?
  county                String?
  lat                   Float?
  lng                   Float?
  // Ownership
  owner                 String?            // Full owner name(s) as-is from Regrid
  owntype               String?            // fee, government, trust, etc.
  ownfrst               String?
  ownlast               String?
  mailadd               String?            // Mailing address line
  mailcity              String?
  mailstate             String?
  mailzip               String?
  // Computed flags
  isAbsentee            Boolean   @default(false) // situs != mailing address
  isVacant              Boolean   @default(false) // USPS vacancy flag
  // Tax / assessment
  parval                Float?             // Total parcel value (assessed)
  landval               Float?             // Land value
  improvval             Float?             // Improvement value
  saleprice             Float?             // Last sale price
  saledate              String?            // Last sale date
  taxamt                Float?             // Annual tax amount
  // Structure
  yearbuilt             Int?
  numstories            Float?
  numunits              Int?
  num_bedrooms          Int?
  num_bath              Float?
  struct                String?            // Primary structure type
  ll_gisacre            Float?             // GIS-computed acreage
  ll_gissqft            Float?             // GIS-computed lot sqft
  // Zoning / special
  zoning                String?
  zoning_description    String?
  usps_vacancy          String?            // Y, N, or null
  qoz                   Boolean   @default(false) // Qualified Opportunity Zone
  // Raw data store
  rawData               Json?              // Full GeoJSON feature properties
  geometry              Json?              // Parcel boundary polygon (GeoJSON)
  // Relations
  listingId             String?   @unique  // 1:1 optional link to MLS Listing
  listing               Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  leads                 Lead[]
  // Cache
  regridFetchedAt       DateTime  @default(now()) // For 30-day TTL
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([zip])
  @@index([county])
  @@index([owner])
  @@index([isAbsentee, isVacant])
  @@index([parcelnumb])
  @@index([lat, lng])
}

// ─── NARRPR Import (Realtors Property Resource) ─────────────

model NarrprImport {
  id               String    @id @default(cuid())
  importType       String    // "csv_bulk" | "rich_detail" | "bookmarklet"
  address          String
  city             String?
  state            String?
  zip              String?
  matchedListingId String?
  matchedDossierId String?
  matchConfidence  Float?
  // CSV bulk fields
