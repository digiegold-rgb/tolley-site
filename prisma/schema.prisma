  subscriberId           String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  facebookUrl            String?
  instagramUrl           String?
  linkedinUrl            String?
  twitterUrl             String?
  tiktokUrl              String?
  buyerSeller            String         @default("buyer")
  preApproved            Boolean        @default(false)
  preApprovalAmount      Float?
  minPrice               Float?
  maxPrice               Float?
  minBeds                Int?
  maxBeds                Int?
  minBaths               Float?
  minSqft                Int?
  maxSqft                Int?
  preferredCities        String[]
  preferredZips          String[]
  preferredPropertyTypes String[]
  moveTimeline           String?
  currentCity            String?
  currentState           String?
  movingFrom             String?
  birthday               String?
  household              String?
  kids                   Int?
  pets                   String?
  occupation             String?
  interests              String[]
