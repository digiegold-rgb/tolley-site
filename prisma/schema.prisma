generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String               @default("none")
  subscriptionTier     String               @default("none")
  currentPeriodEnd     DateTime?
  accounts             Account[]
  agents               Agent[]
  credentialAuth       CredentialAuth?
  deliveryClient       DeliveryClient?
  deliveryDriver       DeliveryDriver?
  foodFamilyMembers    FoodFamilyMember[]
  foodHousehold        FoodHousehold?
  leadSubscription     LeadSubscriber?
  mfaBackupCodes       MfaBackupCode[]
  savedResults         SavedResult[]
  sessions             Session[]
  subscription         Subscription?
  usageBuckets         UsageBucket[]
  usageEvents          UsageEvent[]
  mfa                  UserMfa?
  videoCredit          VideoCredit?
  videoGenerations     VideoGeneration[]
  videoProjects        VideoProject[]
  socialAccounts       SocialAccount[]
  socialShares         SocialShareJob[]
  vaterSubscription    VaterSubscription?
  vaterUsages          VaterUsage[]
  vaterTrialUsage      VaterTrialUsage?
  vaterMonthlyLimit    VaterMonthlyLimit?
  budgetCategories     BudgetCategory[]
  budgetEntries        BudgetEntry[]
  budgetGoals          BudgetGoal[]
  budgetRecurring      BudgetRecurring[]
  budgetPlaidAccounts  BudgetPlaidAccount[]
  shareLinks           ShareLink[]
}

/// Per-user credentials for posting to external social platforms from the
/// vater/youtube Library. Isolated from the global /content portal (which is
/// Jared-specific) so every tolley-site user can connect their own accounts.
///
/// `credentials` is an encrypted-at-rest JSON blob (expected shape differs
/// per platform — YouTube needs refresh_token + client_id/secret, TikTok
/// needs client_key + refresh_token, FB needs page_id + long-lived token,
/// etc). See /api/vater/social-accounts for the per-platform schemas.
model SocialAccount {
  id          String    @id @default(cuid())
  userId      String
  platform    String // "youtube" | "tiktok" | "instagram" | "facebook" | "pinterest" | "twitter" | "linkedin"
  displayName String? // handle / channel name shown in the UI
  avatarUrl   String?
  credentials Json // platform-specific token blob
  status      String    @default("active") // active | expired | error
  lastError   String?
  connectedAt DateTime  @default(now())
  lastUsedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
}

/// Tracks an outbound upload from a vater/youtube project to a social
/// platform. Stub-first: rows are created when the user clicks "Post to X"
/// but the actual platform API call is deferred until OAuth flows land.
model SocialShareJob {
  id           String    @id @default(cuid())
  userId       String
  projectId    String // YouTubeProject.id
  platform     String
  status       String    @default("queued") // queued | posting | posted | failed
  title        String?
  description  String?
  hashtags     String[]  @default([])
  thumbnailUrl String?
  platformUrl  String? // final URL after post (e.g. https://youtu.be/...)
  errorMessage String?
  queuedAt     DateTime  @default(now())
  postedAt     DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, queuedAt])
  @@index([projectId])
  @@index([status])
}

/// Central admin queue for the /social dashboard. Distinct from SocialShareJob
/// (vater-project-scoped) and ContentPost (lead-subscriber-scoped). Each row
/// represents one piece of media that fans out to multiple platforms.
///
/// `source` says where it came from — "manual" (admin upload), "shop"
/// (product syndicate), "realestate" (MLS pull), "vater" (faceless render).
/// `platforms` lists the targets; `externalIds` maps platform -> post URL/id
/// once published. `status` lifecycle: draft -> ready -> posting -> posted | failed.
model SocialPost {
  id           String    @id @default(cuid())
  source       String // manual | shop | realestate | vater
  sourceRefId  String? // Product.id, Listing.id, YouTubeProject.id (nullable for manual)
  mediaUrl     String // CDN/blob URL of the video or image
  mediaType    String    @default("video") // video | image | carousel
  thumbnailUrl String?
  title        String?
  caption      String
  hashtags     String[]  @default([])
  platforms    String[]  @default([]) // youtube | tiktok | instagram | facebook | pinterest
  scheduledAt  DateTime?
  postedAt     DateTime?
  status       String    @default("draft") // draft | ready | posting | posted | failed
  externalIds  Json      @default("{}") // { youtube: "...", tiktok: "..." }
  errorMessage String?
  retryCount   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([source, createdAt])
  @@index([createdAt])
}

model Agent {
  id            String   @id @default(cuid())
  userId        String
  name          String
  rolePurpose   String
  modelProvider String
  systemPrompt  String
  toolsEnabled  String[]
  webhookUrl    String?
  phoneBinding  String?
  emailBinding  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model SavedResult {
  id          String   @id @default(cuid())
  userId      String
  query       String
  title       String
  contentJson Json
  contentText String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CredentialAuth {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  status               String
  priceId              String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id               String   @id @default(cuid())
  userId           String?
  type             String
  createdAt        DateTime @default(now())
  tokensApprox     Int?
  requestId        String?
  latencyMs        Int?
  completionTokens Int?
  endpoint         String?
  errorMessage     String?
  location         String?
  meta             Json?
  model            String?
  promptTokens     Int?
  provider         String?
  route            String?
  statusCode       Int?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@index([model, createdAt])
  @@index([type, createdAt])
}

model UsageBucket {
  id           String   @id @default(cuid())
  userId       String
  bucketDate   DateTime
  countAsks    Int      @default(0)
  countMinutes Int      @default(0)
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bucketDate])
  @@index([userId, lastSeenAt])
}

model ShopItem {
  id                 String    @id @default(cuid())
  title              String
  price              Float
  description        String?
  category           String?
  imageUrls          String[]
  status             String    @default("active")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  soldAt             DateTime?
  shipPrice          Float?
  weightOz           Int?
  amazonAsin         String?
  amazonClicks       Int       @default(0)
  amazonSearchClicks Int       @default(0)
  searchKeywords     String?

  @@index([status, createdAt])
}

model McpInvocation {
  id        String   @id @default(cuid())
  tool      String
  input     Json?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tool, createdAt])
}

model Listing {
  id                String             @id @default(cuid())
  mlsId             String             @unique
  status            String
  listPrice         Float?
  originalListPrice Float?
  address           String
  city              String?
  state             String?            @default("MO")
  zip               String?
  beds              Int?
  baths             Float?
  sqft              Int?
  propertyType      String?
  daysOnMarket      Int?
  onMarketDate      DateTime?
  closeDate         DateTime?
  listingUrl        String?
  photoUrls         String[]
  listAgentName     String?
  listAgentMlsId    String?
  listOfficeName    String?
  listOfficeMlsId   String?
  rawData           Json?
  lastSynced        DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lat               Float?
  lng               Float?
  source            String?            @default("mls")
  Deal              Deal[]
  dossierJobs       DossierJob[]
  leads             Lead[]
  enrichment        ListingEnrichment?
  parcel            Parcel?

  @@index([status, zip])
  @@index([status, daysOnMarket])
  @@index([status, city])
  @@index([lastSynced])
}

model Lead {
  id             String        @id @default(cuid())
  listingId      String?
  score          Int           @default(0)
  scoreFactors   Json?
  status         String        @default("new")
  ownerName      String?
  ownerPhone     String?
  ownerEmail     String?
  notes          String?
  source         String?
  referredTo     String?
  referralStatus String?
  referralFee    Float?
  contactedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  parcelId       String?
  pipelineOrder  Int           @default(0)
  pipelineStage  String        @default("new_lead")
  ContactTag     ContactTag[]
  CrmActivity    CrmActivity[]
  CrmTask        CrmTask[]
  Deal           Deal[]
  listing        Listing?      @relation(fields: [listingId], references: [id])
  parcel         Parcel?       @relation(fields: [parcelId], references: [id])

  @@index([status, score])
  @@index([source, createdAt])
  @@index([referralStatus])
  @@index([parcelId])
  @@index([pipelineStage, pipelineOrder])
  @@index([score(sort: Desc), createdAt(sort: Desc)], map: "Lead_score_desc_createdAt_desc_idx")
}

model PointOfInterest {
  id        String   @id @default(cuid())
  osmId     String?  @unique
  type      String
  name      String?
  lat       Float
  lng       Float
  tags      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([type, lat, lng])
}

